      "search": "const wd=env.get(\"keyword\");const page=env.get(\"page\");const url=`${env.baseUrl}/index.php/vod/search/page/${page}/wd/${wd}.html`;const $=utils_1.kitty.load(await(0,utils_1.req)(url));return $(\".videoContent li\").toArray().map(item=>{const a=$(item).find(\".videoName\");return{id:a.attr(\"href\"),title:a.text().trim(),cover:\"\"};});",

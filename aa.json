      "home": "const cate=env.get(\"category\");const page=env.get(\"page\");let url;if(cate==\"/\"){url=env.baseUrl;}else{url=`${env.baseUrl}/index.php/vod/type/id/${cate}/page/${page}.html`;}const $=utils_1.kitty.load(await(0,utils_1.req)(url));return $(\".videoContent li\").toArray().map(item=>{const a=$(item).find(\".videoName\");const id=a.attr(\"href\")??\"\";const title=a.text().trim();const cover=\"\";const remark=$(item).find(\".time\").text().trim();return{id,title,cover,remark};});",
